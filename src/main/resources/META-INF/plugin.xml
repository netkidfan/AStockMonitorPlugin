<idea-plugin>
    <id>com.stockmonitor.idea-plugin</id>
    <name>A Stock Monitor</name>
    <vendor email="9164705@qq.com" url="">NichaelFan</vendor>
    <description><![CDATA[
        <p><b>A股均线突破监控插件</b></p>
        <p>兼容 IntelliJ IDEA 2021.2 及以上版本</p>
        <ul>
            <li>在 IDEA 左侧边栏实时监控 A 股品种行情</li>
            <li>支持 MA60 多周期均线突破/跌破信号检测（5/15/30分钟）</li>
            <li>东方财富 / 新浪财经 / 腾讯财经三平台自动故障切换</li>
            <li>IDEA 气泡通知弹窗 + 钉钉机器人双通道推送</li>
            <li>所有参数均可在 Settings → Tools → Stock Monitor 中配置</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ── 设置页面 ── -->
        <applicationConfigurable
            parentId="tools"
            instance="com.stockmonitor.settings.StockMonitorConfigurable"
            id="com.stockmonitor.settings.StockMonitorConfigurable"
            displayName="A Stock Monitor（A股监控）"/>

        <!-- ── 持久化状态 ── -->
        <applicationService
            serviceImplementation="com.stockmonitor.settings.StockMonitorSettings"/>

        <!-- ── 后台监控服务 ── -->
        <applicationService
            serviceImplementation="com.stockmonitor.services.MonitorService"/>

        <!-- ── 通知组（用于信号弹窗）── -->
        <notificationGroup
            id="A Stock Monitor Signals"
            displayType="BALLOON"
            key="notification.group.stock.monitor"/>

        <!-- ── 侧边栏 Tool Window ── -->
        <toolWindow
            id="A Stock Monitor"
            secondary="false"
            anchor="left"
            factoryClass="com.stockmonitor.toolwindow.StockMonitorToolWindowFactory"
            icon="/icons/stock_monitor.svg"/>

    </extensions>

    <actions>
        <action id="StockMonitor.StartStop"
                class="com.stockmonitor.actions.ToggleMonitorAction"
                text="切换监控状态"
                description="启动或停止 A 股均线监控"/>
    </actions>

</idea-plugin>
